# ─── Anthropic ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── GitHub ─────────────────────────────────────────────
# A GitHub App or personal access token with repo + webhook scopes
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ─── GitHub OAuth App (for user login) ──────────────────
# 1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Set Authorization callback URL to: http://localhost:3000/api/auth/github/callback
# 3. Copy the Client ID and generate a Client Secret
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=your-client-secret-here

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ────────────────────────────────────────────────
PORT=3000
BASE_URL=https://your-app.up.railway.app
NODE_ENV=production

# ─── Paths ──────────────────────────────────────────────
# Where Claude Code will clone customer repos during runs
WORK_DIR=/tmp/repodoc-runs

# ─── Plans (monthly price in cents) ─────────────────────
PRICE_STARTER=9900
PRICE_PRO=29900
PRICE_TEAM=79900

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
